# ── Application ──────────────────────────────────────────
APP_NAME=ai-software-engineer
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_URL=http://localhost:5173

# ── LLM Providers ────────────────────────────────────────
# Primary: Google Gemini
GOOGLE_API_KEY=

# OpenAI-compatible fallback (OpenAI, Azure, local vLLM, etc.)
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Default LLM provider: gemini | openai
LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-2.0-flash

# ── Embeddings ───────────────────────────────────────────
EMBEDDING_MODEL=text-embedding-004
EMBEDDING_DIMENSION=768

# ── ChromaDB ───────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_COLLECTION=codebase_chunks

# ── Neo4j ──────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme

# ── GitHub ─────────────────────────────────────────────────
GITHUB_TOKEN=

# ── LangSmith (Monitoring) ─────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=ai-software-engineer

# ── Workers ────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
WORKER_CONCURRENCY=4

# ── Storage ────────────────────────────────────────────────
REPOS_DIR=./data/repos
CHROMA_PERSIST_DIR=./data/chroma
