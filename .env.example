# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust values for your environment.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Application ---
APP_NAME="AI Software Engineer for GitHub Repositories"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
API_PREFIX="/api/v1"
ENABLE_DOCS="true"
LOG_LEVEL="INFO"

# Comma-free JSON array for CORS origins.
CORS_ORIGINS='["http://localhost:5173"]'

# --- Neo4j (graph database) ---
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password"
NEO4J_ENABLED="true"

# --- ChromaDB (vector database) ---
CHROMA_HOST="localhost"
CHROMA_PORT="8001"
CHROMA_USE_HTTP="false"
CHROMA_COLLECTION="repo_embeddings"
CHROMA_PERSISTENT_PATH="../data/chroma"

# --- Embeddings ---
EMBEDDING_PROVIDER="jina"      # one of: jina | openai
EMBEDDING_BATCH_SIZE="64"      # chunks per API call for the OpenAI provider
CLASS_LINE_THRESHOLD="80"

# --- Jina embeddings (primary provider) ---
JINA_API_KEY=""
JINA_EMBEDDING_MODEL="jina-embeddings-v3"
JINA_BATCH_SIZE="64"
JINA_API_URL="https://api.jina.ai/v1/embeddings"
JINA_TIMEOUT_SECONDS="60"
JINA_MAX_RETRIES="3"
# JINA_DIMENSIONS=""           # optional Matryoshka size; blank = model default (1024)

# --- LLM provider abstraction (answer generation) ---
LLM_PROVIDER="groq"             # one of: openai | groq
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
GROQ_API_KEY=""
LLM_MODEL="llama-3.3-70b-versatile"
LLM_FALLBACK_MODEL="llama-3.1-8b-instant"

# --- Hybrid retrieval ---
RETRIEVAL_TOP_K="8"
RERANK_TOP_K="5"

# --- Frontend ---
VITE_API_BASE_URL="http://localhost:8000/api/v1"
