# ---------------------------------------------------------------------------
# Copy this file to `.env` and adjust values for your environment.
#   cp .env.example .env
# ---------------------------------------------------------------------------

# --- Application ---
APP_NAME="AI Software Engineer for GitHub Repositories"
APP_VERSION="0.1.0"
ENVIRONMENT="development"
API_PREFIX="/api/v1"
ENABLE_DOCS="true"
LOG_LEVEL="INFO"

# Comma-free JSON array for CORS origins.
CORS_ORIGINS='["http://localhost:5173"]'

# --- Neo4j (graph database) ---
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="password"

# --- ChromaDB (vector database) ---
CHROMA_HOST="localhost"
CHROMA_PORT="8001"
CHROMA_USE_HTTP="false"
CHROMA_COLLECTION="repo_embeddings"
CHROMA_PERSISTENT_PATH="../data/chroma"

# --- Embeddings ---
EMBEDDING_PROVIDER="openai"     # one of: openai | gemini
EMBEDDING_BATCH_SIZE="4"        # chunks per indexer batch (Gemini embeds each chunk separately)
GEMINI_REQUEST_DELAY_SECONDS="4.0"
GEMINI_MAX_RETRIES="8"
EMBEDDING_RATE_LIMIT_RETRIES="6"
CLASS_LINE_THRESHOLD="80"

# --- LLM provider abstraction ---
LLM_PROVIDER="openai"          # one of: openai | gemini
OPENAI_API_KEY=""
GEMINI_API_KEY=""

# --- Frontend ---
VITE_API_BASE_URL="http://localhost:8000/api/v1"
